# ==========================================================================
#  HCTestDash - Environment configuration (onboarding challenge)
#  Copy this file to .env and fill in the values for your server:
#      cp .env.example .env
# ==========================================================================

# General Settings
APP_NAME=HCTestDash
APP_ENV=production
APP_DEBUG=false
APP_URL="https://dash.example.hidencloud.com"
APP_KEY=

# Set FORCE_HTTPS=true only when the site is served over TLS (e.g. behind Cloudflare).
# On a plain-http test box, set it to false so generated links stay on http.
FORCE_HTTPS=true
LARAVEL_CLOUDFLARE_ENABLED=false

# API Salt Configuration (optional but recommended for stability)
# Store your encrypted salt to prevent API token invalidation.
# Find it in your database: SELECT value FROM settings WHERE key = 'encrypted::salt'
# API_SALT_ENCRYPTED=

# --------------------------------------------------------------------------
# Database Settings
# --------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hctestdash
DB_USERNAME=hctestdash
DB_PASSWORD=

# --------------------------------------------------------------------------
# Mail Settings (SMTP)
# --------------------------------------------------------------------------
# Recommended free SMTP for testing: Brevo (https://www.brevo.com) - 300 emails/day, real delivery.
# 1. Create a free Brevo account and verify a sender email.
# 2. Go to "SMTP & API" -> "SMTP" and copy the credentials below.
#    - MAIL_USERNAME is the SMTP login Brevo gives you (looks like 9xxxxxx@smtp-brevo.com).
#    - MAIL_PASSWORD is the SMTP key (NOT your Brevo account password).
# 3. Set MAIL_FROM_ADDRESS to a sender you verified in Brevo.
#
# Alternatives: Gmail (app password) or Mailtrap (sandbox: catches mail, does NOT deliver to a real inbox).
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --------------------------------------------------------------------------
# Cache / Queue / Session
# --------------------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=480

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --------------------------------------------------------------------------
# AWS (optional, for S3 file storage)
# --------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --------------------------------------------------------------------------
# Pusher / websockets (optional)
# --------------------------------------------------------------------------
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
